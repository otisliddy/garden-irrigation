// Template for secrets.h — copy to secrets.h and fill in. secrets.h is git-ignored.
//
//   cp secrets.h.example secrets.h
//
// The AWS IoT cert/key + endpoint are generated by infra (see infra/README.md);
// the deploy step already wrote a real secrets.h for this device. Only the WiFi
// credentials below need filling in by hand.
#pragma once

// ---- WiFi ----
#define WIFI_SSID      "YOUR_WIFI_SSID"
#define WIFI_PASSWORD  "YOUR_WIFI_PASSWORD"

// ---- AWS IoT ----
#define AWS_IOT_ENDPOINT "xxxxxxxxxxxxxx-ats.iot.eu-west-1.amazonaws.com"
#define AWS_THING_NAME   "irrigation-controller-01"

// Amazon Root CA 1
static const char AWS_ROOT_CA[] = R"EOF(
-----BEGIN CERTIFICATE-----
...paste AmazonRootCA1.pem...
-----END CERTIFICATE-----
)EOF";

// Device certificate (device.cert.pem)
static const char AWS_DEVICE_CERT[] = R"EOF(
-----BEGIN CERTIFICATE-----
...paste device.cert.pem...
-----END CERTIFICATE-----
)EOF";

// Device private key (device.private.key)
static const char AWS_PRIVATE_KEY[] = R"EOF(
-----BEGIN RSA PRIVATE KEY-----
...paste device.private.key...
-----END RSA PRIVATE KEY-----
)EOF";
